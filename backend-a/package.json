{
  "name": "backend-a",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Hoth POC backend A — skill BAKED INTO the container image (hard-coded / OOTB Flue)",
  "scripts": {
    "bundle": "node scripts/bundle.mjs",
    "dev": "flue dev --target cloudflare --port 3583",
