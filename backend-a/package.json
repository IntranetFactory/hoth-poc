    "deploy": "flue build --target cloudflare && wrangler deploy --config dist/hoth_poc_backend_a/wrangler.json"
  },
  "dependencies": {
    "@cloudflare/sandbox": "0.12.3",
    "@flue/runtime": "1.0.0-beta.9",
