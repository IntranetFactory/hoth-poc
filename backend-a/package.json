    "agents": "^0.14.2",
    "hono": "^4.8.3",
    "valibot": "^1.1.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.45.0",
    "@flue/cli": "1.0.0-beta.9",
    "wrangler": "^4.78.0"
  }
}
