{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "hoth-poc-backend-b",
  "compatibility_date": "2026-06-01",
  "compatibility_flags": ["nodejs_compat"],
  // Flue v2 generates one DO class per agent (FlueHothAgent, from the `hoth`
  // identity). The beta-era FlueRegistry class is gone in v2, hence the v3
  // deleted_classes entry (append-only history).
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["FlueRegistry", "FlueHothAgent"] },
    { "tag": "v2", "new_sqlite_classes": ["HothSandbox"] },
    { "tag": "v3", "deleted_classes": ["FlueRegistry"] }
  ],
  "durable_objects": {
    "bindings": [{ "name": "Sandbox", "class_name": "HothSandbox" }]
  },
  // placement stays "smart" (default) — "targeted" breaks outboundByHost
  // header injection (sandbox-sdk#661, plan §7).
  "containers": [
    {
      "class_name": "HothSandbox",
      "image": "./Dockerfile",
      // Build context = repo root so the image can COPY the shared semantius
      // CLI from ../linux-x64/ (single binary, no per-backend duplication).
      // Kept small by the repo-root .dockerignore.
      "image_build_context": "..",
      "instance_type": "lite"
    }
  ],
  "kv_namespaces": [
    { "binding": "STORE", "id": "6799aa42675b47148d246feda057a0e5" }
  ],
  // Workers AI binding — required when LLM_PROVIDER=cloudflare (no API key needed).
  "ai": { "binding": "AI" },
  "vars": {
    // LLM settings: provider cloudflare | openrouter | custom ("custom" also
    // requires LLM_BASE_URL). The API key is the LLM_API_KEY secret
    // (.dev.vars locally, wrangler secret put when deployed).
    "LLM_PROVIDER": "openrouter",
    "LLM_MODEL": "deepseek/deepseek-v4-flash"
  }
}
