--- a/dist/index.js
+++ b/dist/index.js
@@ -1804,6 +1804,12 @@ async function streamInternal(options) {
 	const startOffset = options.offset ?? `-1`;
 	fetchUrl.searchParams.set(OFFSET_QUERY_PARAM, startOffset);
 	const live = options.live ?? true;
+	// PATCH (hoth-poc): open the held SSE connection on the FIRST request in
+	// sse mode, instead of doing JSON catch-up reads until upToDate. Without
+	// this, observing a live-generating agent never reaches upToDate and the
+	// client busy-polls catch-up reads at network speed. The server streams
+	// catch-up + live over one SSE connection from any offset.
+	if (live === `sse`) fetchUrl.searchParams.set(LIVE_QUERY_PARAM, `sse`);
 	const params = await resolveParams(options.params);
 	for (const [key, value] of Object.entries(params)) fetchUrl.searchParams.set(key, value);
 	const headers = await resolveHeaders(options.headers);
